---
/**
 * Página de trabalho — casting tipográfico + paletas da v2.
 * Não entra no site final: remover (ou bloquear) antes do deploy.
 * Clash Display vem do CDN da Fontshare SÓ aqui; se aprovada, baixamos os woff2.
 */
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque/index.css";
import "@fontsource-variable/syne/index.css";
import { chapters, descarte, paper } from "../../config/chapters";

/* Contraste WCAG 2.x */
function lin(c: number): number {
  const v = c / 255;
  return v <= 0.04045 ? v / 12.92 : Math.pow((v + 0.055) / 1.055, 2.4);
}
function luminance(hex: string): number {
  const h = hex.replace("#", "");
  const [r, g, b] = [0, 2, 4].map((i) => parseInt(h.slice(i, i + 2), 16));
  return 0.2126 * lin(r) + 0.7152 * lin(g) + 0.0722 * lin(b);
}
function ratio(a: string, b: string): number {
  const [l1, l2] = [luminance(a), luminance(b)].sort((x, y) => y - x);
  return (l1 + 0.05) / (l2 + 0.05);
}
const fmt = (n: number) => n.toFixed(2).replace(".", ",");

const candidates = [
  {
    id: "bricolage",
    letra: "A",
    nome: "Bricolage Grotesque",
    family: '"Bricolage Grotesque Variable", sans-serif',
    pesos: [300, 400, 500, 600, 700, 800],
    nota: "Expressiva e quente. Curvas com personalidade, mas segue grotesque: não briga com a Inter no corpo.",
  },
  {
    id: "clash",
    letra: "B",
    nome: "Clash Display",
    family: '"Clash Display", sans-serif',
    pesos: [400, 500, 600, 700],
    nota: "Display contemporânea de verdade. Cortes angulares característicos, presença editorial forte.",
  },
  {
    id: "syne",
    letra: "C",
    nome: "Syne",
    family: '"Syne Variable", sans-serif',
    pesos: [400, 500, 600, 700, 800],
    nota: "A mais artística das três. Geometria estranha no jeito bom; risco e caráter em doses maiores.",
  },
];

const checksFor = (p: (typeof chapters)[number]["palette"]) => [
  { rotulo: "Texto principal sobre fundo", fg: p.foreground, bg: p.background },
  { rotulo: "Texto secundário sobre fundo", fg: p.muted, bg: p.background },
  { rotulo: "Acento como texto sobre fundo", fg: p.accent, bg: p.background },
  { rotulo: "Branco sobre acento (botão)", fg: "#FFFFFF", bg: p.accent },
  { rotulo: "Claro sobre profundo (impacto)", fg: paper, bg: p.deep },
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Casting tipográfico · Portfolio Experience v2</title>
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&display=swap"
    />
  </head>
  <body>
    <header class="topo">
      <p class="eyebrow">Portfolio Experience v2 · Fase 1</p>
      <h1>Casting tipográfico + paletas dos capítulos</h1>
      <p class="lede">
        Três candidatas a display autoral (o corpo segue Inter). Abaixo, as
        cinco atmosferas de capítulo com os contrastes calculados ao vivo.
      </p>
    </header>

    {
      candidates.map((c) => (
        <section class="cand" id={`cand-${c.id}`}>
          <div class="cand-meta">
            <span class="badge">{c.letra}</span>
            <div>
              <h2>{c.nome}</h2>
              <p>{c.nota}</p>
            </div>
          </div>

          <div class="hero-mock" style={`--display: ${c.family}`}>
            <p class="eyebrow">UI/UX Designer Sênior · 15+ anos</p>
            <p class="nome">
              Amilton<br />Schlemper
            </p>
            <p class="tag">
              Crio produtos digitais fáceis de usar e difíceis de esquecer.
            </p>
            <p class="frase">O pensamento vem antes da tela.</p>
          </div>

          <div class="specimen" style={`--display: ${c.family}`}>
            <div class="pesos">
              {c.pesos.map((w) => (
                <span style={`font-weight: ${w}`}>Aa {w}</span>
              ))}
            </div>
            <p class="glifos">Ação, decisão, hipótese: çãõáéíóúê · 0123456789</p>
            <p class="kicker">perguntas, rabiscos, testes, descartes</p>
          </div>
        </section>
      ))
    }

    <section class="paletas" id="paletas">
      <h2 class="secao-titulo">As cinco atmosferas</h2>
      <p class="lede">
        Fundo claro tingido pela dominante, um momento de impacto por capítulo
        (fundo inunda com a versão profunda). Vermelho aparece só nos descartes
        do Pensamento.
      </p>

      <div class="grade">
        {
          chapters.map((ch) => (
            <article
              class="cap"
              id={`cap-${ch.id}`}
              style={`background:${ch.palette.background}; color:${ch.palette.foreground}`}
            >
              <p class="cap-eyebrow" style={`color:${ch.palette.muted}`}>
                Capítulo {ch.numero}
              </p>
              <h3 class="cap-nome">{ch.label}</h3>
              <p class="cap-papel" style={`color:${ch.palette.muted}`}>
                {ch.papel}
              </p>

              <div class="chips">
                <span
                  class="chip"
                  style={`background:${ch.palette.accent}; color:#fff`}
                >
                  Ação primária
                </span>
                <span
                  class="chip ghost"
                  style={`border-color:${ch.palette.muted}; color:${ch.palette.accent}`}
                >
                  Acento como texto
                </span>
                {ch.id === "pensamento" && (
                  <span class="chip" style={`background:${descarte}; color:#fff`}>
                    descartado
                  </span>
                )}
              </div>

              <div
                class="impacto"
                style={`background:${ch.palette.deep}; color:${paper}`}
              >
                momento de impacto
              </div>

              <div class="swatches">
                {Object.entries(ch.palette).map(([nome, hex]) => (
                  <div class="swatch">
                    <span class="cor" style={`background:${hex}`} />
                    <span class="hex">
                      {nome} {hex}
                    </span>
                  </div>
                ))}
              </div>

              <table class="checks">
                {checksFor(ch.palette).map((k) => {
                  const r = ratio(k.fg, k.bg);
                  const ok = r >= 4.5;
                  return (
                    <tr>
                      <td>{k.rotulo}</td>
                      <td class="num">{fmt(r)}:1</td>
                      <td class={ok ? "ok" : "falha"}>{ok ? "AA ✓" : "✗"}</td>
                    </tr>
                  );
                })}
              </table>
            </article>
          ))
        }
      </div>
    </section>

    <footer class="rodape">
      <p>
        Página de trabalho local. Corpo de texto em todas as opções: Inter
        Variable. A escolhida vira o token <code>--font-display</code> na Fase 1b.
      </p>
    </footer>
  </body>
</html>

<style>
  :root {
    --ink: #1c1917;
    --muted: #57534e;
    --bg: #faf9f6;
    --line: #e7e0d8;
  }
  * {
    margin: 0;
    box-sizing: border-box;
  }
  body {
    background: var(--bg);
    color: var(--ink);
    font-family: "Inter Variable", system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    line-height: 1.5;
  }
  .topo {
    padding: 5rem 6vw 3rem;
    max-width: 1200px;
  }
  h1 {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    letter-spacing: -0.02em;
    margin-top: 1rem;
  }
  .eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .lede {
    color: var(--muted);
    max-width: 46rem;
    margin-top: 0.75rem;
  }

  .cand {
    border-top: 1px solid var(--line);
    padding: 3.5rem 6vw 4rem;
  }
  .cand-meta {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    max-width: 46rem;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    background: var(--ink);
    color: var(--bg);
    font-weight: 600;
    flex-shrink: 0;
  }
  .cand-meta h2 {
    font-size: 1.15rem;
    letter-spacing: -0.01em;
  }
  .cand-meta p {
    color: var(--muted);
    font-size: 0.95rem;
    margin-top: 0.25rem;
  }

  .hero-mock {
    margin-top: 2.5rem;
  }
  .hero-mock .nome {
    font-family: var(--display);
    font-weight: 700;
    font-size: clamp(3.5rem, 11vw, 9rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin-top: 1.25rem;
  }
  .hero-mock .tag {
    margin-top: 1.5rem;
    font-size: 1.15rem;
    color: var(--muted);
    max-width: 34rem;
  }
  .hero-mock .frase {
    font-family: var(--display);
    font-weight: 500;
    font-size: clamp(1.5rem, 3.2vw, 2.5rem);
    letter-spacing: -0.01em;
    margin-top: 2.25rem;
  }

  .specimen {
    margin-top: 2rem;
    border: 1px solid var(--line);
    border-radius: 1rem;
    padding: 1.5rem;
    max-width: 60rem;
  }
  .pesos {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem 2rem;
    font-family: var(--display);
    font-size: 1.75rem;
  }
  .glifos {
    font-family: var(--display);
    font-weight: 500;
    font-size: 1.35rem;
    margin-top: 1.25rem;
  }
  .kicker {
    font-family: var(--display);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.85rem;
    margin-top: 1rem;
    color: var(--muted);
  }

  .paletas {
    border-top: 1px solid var(--line);
    padding: 3.5rem 6vw 4rem;
  }
  .secao-titulo {
    font-size: 1.5rem;
    letter-spacing: -0.01em;
  }
  .grade {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.25rem;
    margin-top: 2rem;
  }
  .cap {
    border-radius: 1.25rem;
    padding: 1.75rem;
    border: 1px solid rgb(0 0 0 / 0.06);
  }
  .cap-eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .cap-nome {
    font-size: 2rem;
    letter-spacing: -0.02em;
    margin-top: 0.5rem;
  }
  .cap-papel {
    font-size: 0.9rem;
    margin-top: 0.5rem;
    min-height: 2.7em;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }
  .chip {
    border-radius: 999px;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    font-weight: 500;
  }
  .chip.ghost {
    border: 1px solid;
    background: transparent;
  }
  .impacto {
    margin-top: 1rem;
    border-radius: 0.75rem;
    padding: 1.25rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    margin-top: 1.25rem;
  }
  .swatch {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
  }
  .cor {
    width: 1rem;
    height: 1rem;
    border-radius: 999px;
    border: 1px solid rgb(0 0 0 / 0.12);
  }
  .checks {
    width: 100%;
    margin-top: 1.25rem;
    border-collapse: collapse;
    font-size: 0.8rem;
  }
  .checks td {
    padding: 0.35rem 0;
    border-top: 1px solid rgb(0 0 0 / 0.08);
  }
  .checks .num {
    text-align: right;
    font-variant-numeric: tabular-nums;
    padding-right: 0.75rem;
  }
  .checks .ok {
    text-align: right;
    font-weight: 600;
    color: #15803d;
  }
  .checks .falha {
    text-align: right;
    font-weight: 700;
    color: #d92d20;
  }
  .rodape {
    border-top: 1px solid var(--line);
    padding: 2rem 6vw 4rem;
    color: var(--muted);
    font-size: 0.9rem;
  }
  code {
    font-size: 0.85em;
  }
</style>
