---
/**
 * Página de case — serve dois contextos com o MESMO artigo:
 * 1. Visita direta / deep-link / sem JS: página completa (header + footer).
 * 2. Overlay na home: o CaseOverlay busca este HTML e injeta só o que está
 *    dentro de [data-case-conteudo].
 *
 * CONTRATO: nada dentro do artigo pode depender de <style> com escopo
 * Astro (o overlay injeta o HTML fora desta página). Só utilitários
 * Tailwind e classes globais do global.css.
 */
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import Footer from "../../components/Footer.astro";
import SymbolMark from "../../components/SymbolMark.astro";
import { whatsappUrl } from "../../config/site";
import { Image } from "astro:assets";
import WhatsApp from "../../components/icons/WhatsApp.astro";

export async function getStaticPaths() {
  const sorted = (await getCollection("projects")).sort(
    (a, b) => a.data.order - b.data.order,
  );
  const n = sorted.length;
  return sorted.map((project, i) => ({
    params: { slug: project.id },
    props: {
      project,
      prev: sorted[(i - 1 + n) % n],
      next: sorted[(i + 1) % n],
    },
  }));
}

const { project, prev, next } = Astro.props;
const { Content } = await render(project);
const d = project.data;
const waHref = whatsappUrl(
  `Oi, Amilton! Vi o case "${d.title}" no seu site e quero conversar sobre um projeto parecido.`,
);
---

<Base title={`${d.title} · Amilton Schlemper`} description={d.summary}>
  <div class="case-tema bg-background text-foreground">
    <header class="wrap flex items-center justify-between py-5">
      <a
        href="/"
        class="inline-flex items-center gap-2.5 text-sm font-medium tracking-tight"
      >
        <SymbolMark class="size-5 shrink-0" />
        <span class="link-line">Amilton Schlemper</span>
      </a>
      <a
        href={waHref}
        target="_blank"
        rel="noopener"
        class="btn btn-ghost px-4! py-2! text-sm"
      >
        <WhatsApp class="size-4" /> WhatsApp
      </a>
    </header>

    <main class="mx-auto w-full max-w-[878px] px-6 pt-16 md:pt-24">
      <a
        href="/#evidencias"
        class="link-line text-sm text-muted transition-colors hover:text-foreground"
        >← Voltar às provas</a
      >

      <article data-case-conteudo>
        <header class="mt-8 border-b border-border pb-12">
          <p class="eyebrow">{d.category}</p>
          <h1
            class="mt-5 font-display font-semibold leading-[0.95] tracking-tight text-[clamp(2.5rem,9vw,6.5rem)]"
          >
            {d.title}
          </h1>
          {
            d.area && (
              <p class="mt-3 font-display text-2xl font-medium tracking-tight text-muted md:text-3xl">
                {d.area}
              </p>
            )
          }
          <div class="mt-8 grid max-w-md grid-cols-2 gap-6 text-sm">
            <div>
              <div class="eyebrow">Papel</div>
              <div class="mt-2">{d.role}</div>
            </div>
            <div>
              <div class="eyebrow">Ano</div>
              <div class="mt-2 tabular-nums">{d.year}</div>
            </div>
          </div>
        </header>

        <div
          class="mt-12 aspect-[16/9] w-full overflow-hidden rounded-xl border border-border bg-surface"
        >
          {
            d.cover ? (
              <Image
                src={d.cover}
                alt={d.title}
                widths={[768, 1280, 1920]}
                sizes="(max-width: 1200px) 100vw, 878px"
                class="h-full w-full object-cover"
              />
            ) : (
              <div
                aria-hidden="true"
                class="flex h-full items-center justify-center font-display text-7xl font-semibold tracking-tighter text-faint"
              >
                {d.glyph ?? d.title.slice(0, 2)}
              </div>
            )
          }
        </div>

        <div class="prose-case mt-16">
          <Content />
        </div>

        <nav
          class="mt-24 grid grid-cols-2 gap-4 border-t border-border pt-10"
          aria-label="Outros cases"
        >
          <a href={`/trabalho/${prev.id}`} class="group">
            <div class="eyebrow">Anterior</div>
            <div
              class="mt-2 font-display text-xl font-semibold transition-colors group-hover:text-accent"
            >
              {prev.data.title}
            </div>
          </a>
          <a href={`/trabalho/${next.id}`} class="group text-right">
            <div class="eyebrow">Próximo</div>
            <div
              class="mt-2 font-display text-xl font-semibold transition-colors group-hover:text-accent"
            >
              {next.data.title}
            </div>
          </a>
        </nav>

        <div
          class="mt-16 rounded-xl border border-border bg-surface p-8 text-center md:p-12"
        >
          <p
            class="font-display text-2xl font-semibold tracking-tight md:text-3xl"
          >
            Tem um projeto parecido?
          </p>
          <a
            href={waHref}
            target="_blank"
            rel="noopener"
            class="btn btn-whatsapp mt-6"
          >
            <WhatsApp class="size-5" /> Falar no WhatsApp
          </a>
        </div>
      </article>
    </main>
    <Footer />
  </div>
</Base>
