---
import { whatsappUrl } from "../config/site";
import WhatsApp from "./icons/WhatsApp.astro";
import SymbolMark from "./SymbolMark.astro";
const waHref = whatsappUrl(
  "Oi, Amilton! Vim pelo seu site e quero conversar sobre um projeto.",
);
---

<header id="nav" class="fixed inset-x-0 top-0 z-50 transition-all duration-500">
  <nav class="wrap flex items-center justify-between py-5">
    <a href="#top" class="inline-flex items-center gap-2.5 text-sm font-medium tracking-tight">
      <SymbolMark class="size-5 shrink-0" />
      <span class="link-line">Amilton Schlemper</span>
    </a>
    <div class="flex items-center gap-6 text-sm md:gap-8">
      <a href="#trabalho" class="link-line hidden text-muted transition-colors hover:text-foreground sm:inline">Trabalho</a>
      <a href="#sobre" class="link-line hidden text-muted transition-colors hover:text-foreground sm:inline">Sobre</a>
      <a
        href={waHref}
        target="_blank"
        rel="noopener"
        class="btn btn-ghost px-4! py-2! text-sm"
      >
        <WhatsApp class="size-4" /> WhatsApp
      </a>
    </div>
  </nav>
</header>

<style>
  #nav.nav-scrolled {
    background-color: color-mix(in oklab, var(--color-background) 70%, transparent);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }
</style>

<script>
  function initNav() {
    const nav = document.getElementById("nav");
    if (!nav) return;
    const onScroll = () =>
      nav.classList.toggle("nav-scrolled", window.scrollY > 24);
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }
  document.addEventListener("astro:page-load", initNav);
</script>
