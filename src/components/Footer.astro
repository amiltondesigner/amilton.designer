---
import { site } from "../config/site";
import Socials from "./Socials.astro";
import SymbolMark from "./SymbolMark.astro";
const year = new Date().getFullYear();
---

<footer class="wrap border-t border-border py-12">
  <div class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
    <div>
      <a href="#top" class="inline-flex items-center gap-2.5 font-medium">
        <SymbolMark class="size-6 shrink-0" /> Amilton Schlemper
      </a>
      <p class="mt-3 text-sm text-faint">{site.location}</p>
    </div>
    <Socials />
  </div>
  <div
    class="mt-10 flex flex-col gap-2 text-sm text-faint md:flex-row md:items-center md:justify-between"
  >
    <span class="tabular-nums">© {year} {site.name} · Todos os direitos reservados</span>
    <a href="#top" class="link-line transition-colors hover:text-foreground"
      >Voltar ao topo ↑</a
    >
  </div>
</footer>
