---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<section id="trabalho" class="wrap scroll-mt-24 py-24 md:py-36">
  <div class="flex items-end justify-between gap-6" data-reveal>
    <h2 class="eyebrow">Trabalho selecionado</h2>
    <span class="text-sm tabular-nums text-faint">
      {String(projects.length).padStart(2, "0")} projetos
    </span>
  </div>

  <div
    class="mt-10 grid grid-cols-1 gap-x-6 gap-y-12 md:mt-16 md:grid-cols-12 md:gap-y-24"
  >
    {
      projects.map((p, i) => (
        <a
          href={`/trabalho/${p.id}`}
          class:list={[
            "group block",
            p.data.span === "wide" ? "md:col-span-7" : "md:col-span-5",
            i % 2 === 1 && "md:mt-16",
          ]}
          data-reveal="scale"
          style={`--reveal-delay:${(i % 2) * 100}ms`}
        >
          <div
            class="relative overflow-hidden rounded-lg border border-border bg-surface transition-colors duration-500 group-hover:border-accent/40"
            style={`view-transition-name: cover-${p.id}`}
          >
            <div class="aspect-[4/3] w-full">
              {
                p.data.cover ? (
                  <Image
                    src={p.data.cover}
                    alt={p.data.title}
                    widths={[480, 768, 1024]}
                    sizes="(max-width: 768px) 100vw, 45vw"
                    class="h-full w-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-105"
                  />
                ) : (
                  <span aria-hidden="true" class="absolute inset-0 flex items-center justify-center font-display font-bold tracking-tighter text-[#71717a] text-[clamp(3rem,10vw,6rem)] transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-105">
                    {p.data.glyph ?? p.data.title.slice(0, 2)}
                  </span>
                )
              }
            </div>
            <span class="absolute right-4 top-4 flex size-9 -translate-y-1.5 items-center justify-center rounded-full bg-foreground text-background opacity-0 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:translate-y-0 group-hover:opacity-100">
              ↗
            </span>
          </div>

          <div class="mt-5 flex items-baseline justify-between gap-4">
            <h3
              class="font-display text-2xl font-semibold tracking-tight transition-colors duration-300 group-hover:text-accent md:text-3xl"
              style={`view-transition-name: title-${p.id}`}
            >
              {p.data.title}
            </h3>
            <span class="shrink-0 text-sm tabular-nums text-faint">
              {p.data.year}
            </span>
          </div>
          <p class="mt-2 text-muted">{p.data.summary}</p>
          <div class="mt-3 flex items-center justify-between gap-4">
            <p class="eyebrow">{p.data.category}</p>
            <span class="inline-flex items-center gap-1.5 text-sm text-faint transition-colors group-hover:text-accent">
              Ver case
              <span
                aria-hidden="true"
                class="transition-transform group-hover:translate-x-0.5"
                >→</span
              >
            </span>
          </div>
        </a>
      ))
    }
  </div>
</section>
