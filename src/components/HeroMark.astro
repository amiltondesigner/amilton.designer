---
/**
 * Marca do hero: o símbolo A+S do Amilton (peso bold, fonte única em
 * config/mark). Traço em grafite translúcido, sangrando pela borda direita.
 * Na saída da Abertura ele explode em direção à câmera (ver Abertura.astro).
 * Nunca recrio o símbolo: o visível é sempre o vetor dele.
 */
import { AM_MARK, MARK_VIEWBOX } from "../config/mark";
---

<div class="hero-mark" aria-hidden="true">
  <svg class="hero-mark__svg" viewBox={MARK_VIEWBOX} fill="none">
    <!-- pathLength normaliza o comprimento em 1: o contorno "desenha" via
         stroke-dashoffset 1→0 antes de preencher (ver Abertura.astro) -->
    <path d={AM_MARK} class="am-mark" pathLength="1" />
  </svg>
</div>

<style>
  .hero-mark {
    position: absolute;
    right: clamp(-12rem, -7vw, -5rem);
    top: 50%;
    transform: translateY(-50%);
    width: clamp(440px, 56vw, 900px);
    aspect-ratio: 1 / 1;
    z-index: 0;
    pointer-events: none;
    display: none;
  }
  @media (min-width: 768px) {
    .hero-mark {
      display: block;
    }
  }

  .hero-mark__svg {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .am-mark {
    fill: color-mix(in oklab, var(--ch-fg) 14%, transparent);
    transition: fill 0.9s var(--ease-soft);
  }
</style>
