---
/**
 * Símbolo A+S do Amilton, estático (sem animação). Vetor da fonte única
 * (config/mark, peso bold). Herda a cor via currentColor. Tamanho pela
 * prop class (ex.: size-6).
 */
import { AM_MARK, MARK_VIEWBOX } from "../config/mark";

interface Props {
  class?: string;
}
const { class: className = "size-6" } = Astro.props;
---

<svg
  viewBox={MARK_VIEWBOX}
  fill="currentColor"
  aria-hidden="true"
  class={className}
>
  <path d={AM_MARK}></path>
</svg>
