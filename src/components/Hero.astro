---
import { site } from "../config/site";
import HeroMark from "./HeroMark.astro";
import Socials from "./Socials.astro";
---

<section
  id="top"
  class="relative flex min-h-svh flex-col justify-center overflow-hidden pt-24"
>
  <div class="hero-glow"></div>
  <HeroMark />
  <div class="wrap relative z-10">
    <p class="eyebrow" data-reveal>
      {site.role} · {site.yearsOfExperience}+ anos
    </p>
    <h1
      class="mt-6 font-display font-bold leading-[0.9] tracking-[-0.03em] text-[clamp(2.75rem,11vw,9.5rem)]"
    >
      <span class="block" data-reveal style="--reveal-delay:80ms">Amilton</span>
      <span class="block" data-reveal style="--reveal-delay:160ms"
        >Schlemper</span
      >
    </h1>
    <p
      class="mt-8 max-w-xl text-lg leading-relaxed text-muted md:text-xl"
      data-reveal
      style="--reveal-delay:260ms"
    >
      {site.tagline}
    </p>
    <div
      class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-faint"
      data-reveal
      style="--reveal-delay:340ms"
    >
      <span class="inline-flex items-center gap-2">
        <span class="size-1.5 rounded-full bg-accent"></span> Disponível para freelance
      </span>
      <span>{site.location}</span>
    </div>
    <div class="mt-8" data-reveal style="--reveal-delay:420ms">
      <Socials />
    </div>
    <a
      href="#trabalho"
      class="mt-24 inline-flex items-center gap-3 text-sm text-muted transition-colors hover:text-foreground"
      data-reveal
      style="--reveal-delay:480ms"
    >
      <span class="scroll-cue" aria-hidden="true"></span> Role para ver o trabalho
    </a>
  </div>
</section>

<style>
  .scroll-cue {
    position: relative;
    display: inline-block;
    width: 1px;
    height: 2.5rem;
    background: linear-gradient(
      to bottom,
      var(--color-faint),
      transparent
    );
    overflow: hidden;
  }
  .scroll-cue::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--color-accent);
    animation: cue 2.2s var(--ease-out-expo) infinite;
  }
  @keyframes cue {
    0% { transform: translateY(-100%); }
    60%,
    100% { transform: translateY(100%); }
  }
</style>
