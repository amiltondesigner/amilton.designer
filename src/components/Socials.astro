---
import { site } from "../config/site";

interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;

const socials = [
  { label: "Behance", href: site.social.behance },
  { label: "Dribbble", href: site.social.dribbble },
  { label: "Figma", href: site.social.figma },
  { label: "LinkedIn", href: site.social.linkedin },
];
---

<!-- lista simples, sem landmark: o componente aparece 2x na home e
     dois <nav> iguais viram ruído pra leitores de tela (landmark-unique) -->
<ul
  class:list={[
    "flex list-none flex-wrap gap-x-6 gap-y-2 p-0 text-sm",
    className,
  ]}
>
  {
    socials.map((s) => (
      <li>
        <a
          href={s.href}
          target="_blank"
          rel="noopener"
          class="link-line text-muted transition-colors hover:text-foreground"
        >
          {s.label}
        </a>
      </li>
    ))
  }
</ul>
