---
/**
 * Capítulo 02 — Descoberta. Quem pensa assim, sem seção "Sobre":
 * o nome chega grande e a bio vem em fragmentos. Entra o azul.
 */
import { Image } from "astro:assets";
import avatar from "../../assets/avatar.png";
import { site, services } from "../../config/site";
import Socials from "../Socials.astro";
---

<section
  id="descoberta"
  data-chapter-section="descoberta"
  class="wrap scroll-mt-24 py-28 md:py-44"
>
  <p class="kicker text-accent">Capítulo 02 · Quem pensa assim</p>

  <h2 class="display-1 mt-6">
    Amilton<br />Schlemper
  </h2>

  <div class="mt-16 grid grid-cols-1 gap-12 md:mt-24 md:grid-cols-12 md:gap-16">
    <div class="md:col-span-7">
      <p
        class="font-display text-3xl font-medium leading-[1.15] tracking-tight md:text-4xl"
      >
        {site.bio}
      </p>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-muted">
        Já atuei como Diretor de Arte e Designer de Produto, com passagem por
        sistemas de governo (gov-tech), e-commerce, identidade visual e
        branding. Hoje desenho produtos digitais que unem clareza, estética e
        resultado.
      </p>

      <div class="mt-12 flex items-end gap-8">
        <div>
          <div class="font-display text-5xl font-semibold tabular-nums">
            {site.yearsOfExperience}+
          </div>
          <div class="eyebrow mt-2">anos de experiência</div>
        </div>
        <div class="h-12 w-px bg-border"></div>
        <div>
          <div class="font-display text-5xl font-semibold tabular-nums">
            {String(services.length).padStart(2, "0")}
          </div>
          <div class="eyebrow mt-2">áreas de atuação</div>
        </div>
      </div>

      <div
        class="mt-10 grid grid-cols-2 gap-px overflow-hidden rounded-lg border border-border bg-border"
      >
        {
          services.map((s) => (
            <div class="bg-background p-4 transition-colors duration-700 md:p-5">
              <span class="text-sm md:text-base">{s.label}</span>
            </div>
          ))
        }
      </div>

      <div
        class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-faint"
      >
        <span class="inline-flex items-center gap-2">
          <span class="size-1.5 rounded-full bg-accent"></span> Disponível para
          freelance
        </span>
        <span>{site.location}</span>
      </div>
      <div class="mt-6">
        <Socials />
      </div>
    </div>

    <div class="md:col-span-5">
      <div
        class="aspect-[4/5] w-full overflow-hidden rounded-lg border border-border bg-surface md:sticky md:top-28"
      >
        <Image
          src={avatar}
          alt={`Retrato de ${site.name}`}
          width={840}
          height={840}
          class="h-full w-full object-cover"
        />
      </div>
    </div>
  </div>
</section>
