---
/**
 * Capítulo 02 — Descoberta. Quem pensa assim, sem seção "Sobre":
 * o nome chega grande (linhas mascaradas) e a bio vem em fragmentos
 * que o scroll revela. Entra o azul. Cenas só no desktop; o HTML
 * nasce completo e visível.
 */
import { Image } from "astro:assets";
import avatar from "../../assets/avatar.png";
import { site, services } from "../../config/site";
import Socials from "../Socials.astro";
---

<section
  id="descoberta"
  data-chapter-section="descoberta"
  class="wrap scroll-mt-24 py-28 md:py-44"
>
  <p class="kicker text-accent" data-anima="fade">
    Capítulo 02 · Quem pensa assim
  </p>

  <h2 class="display-1 mt-6" data-descoberta-nome>
    <span class="linha"><span class="linha-inner">Amilton</span></span>
    <span class="linha"><span class="linha-inner">Schlemper</span></span>
  </h2>

  <div class="mt-16 grid grid-cols-1 gap-12 md:mt-24 md:grid-cols-12 md:gap-16">
    <div class="md:col-span-7">
      <p
        class="font-display text-3xl font-medium leading-[1.15] tracking-tight md:text-4xl"
        data-anima
      >
        {site.bio}
      </p>
      <p
        class="mt-6 max-w-2xl text-lg leading-relaxed text-muted"
        data-anima
        data-anima-delay="0.1"
      >
        Já atuei como Diretor de Arte e Designer de Produto, com passagem por
        sistemas de governo (gov-tech), e-commerce, identidade visual e
        branding. Hoje desenho produtos digitais que unem clareza, estética e
        resultado.
      </p>

      <div class="mt-12 flex items-end gap-8" data-anima>
        <div>
          <div
            class="font-display text-5xl font-semibold tabular-nums"
            data-contagem={site.yearsOfExperience}
            data-contagem-sufixo="+"
          >
            {site.yearsOfExperience}+
          </div>
          <div class="eyebrow mt-2">anos de experiência</div>
        </div>
        <div class="h-12 w-px bg-border"></div>
        <div>
          <div
            class="font-display text-5xl font-semibold tabular-nums"
            data-contagem={services.length}
            data-contagem-pad="2"
          >
            {String(services.length).padStart(2, "0")}
          </div>
          <div class="eyebrow mt-2">áreas de atuação</div>
        </div>
      </div>

      <div
        class="mt-10 grid grid-cols-2 gap-px overflow-hidden rounded-lg border border-border bg-border"
        data-anima-grupo
      >
        {
          services.map((s) => (
            <div class="bg-background p-4 transition-colors duration-700 md:p-5">
              <span class="text-sm md:text-base">{s.label}</span>
            </div>
          ))
        }
      </div>

      <div
        class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-faint"
        data-anima="fade"
      >
        <span class="inline-flex items-center gap-2">
          <span class="size-1.5 rounded-full bg-accent"></span> Disponível para
          freelance
        </span>
        <span>{site.location}</span>
      </div>
      <div class="mt-6" data-anima="fade" data-anima-delay="0.1">
        <Socials />
      </div>
    </div>

    <div class="md:col-span-5">
      <div
        class="aspect-[4/5] w-full overflow-hidden rounded-lg border border-border bg-surface md:sticky md:top-28"
        data-anima="scale"
      >
        <Image
          src={avatar}
          alt={`Retrato de ${site.name}`}
          width={840}
          height={840}
          class="h-full w-full scale-[1.08] object-cover"
          data-descoberta-foto
        />
      </div>
    </div>
  </div>
</section>

<style>
  .linha {
    display: block;
    overflow: hidden;
    padding-bottom: 0.12em;
    margin-bottom: -0.12em;
  }
  .linha-inner {
    display: inline-block;
    will-change: transform;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { registerScene } from "../../scripts/experience";

  registerScene(() => {
    const section = document.getElementById("descoberta");
    if (!section) return;

    // O nome chega grande, linha a linha
    const linhas = section.querySelectorAll<HTMLElement>(".linha-inner");
    if (linhas.length) {
      gsap.from(linhas, {
        yPercent: 112,
        duration: 1.1,
        ease: "expo.out",
        stagger: 0.12,
        scrollTrigger: {
          trigger: section,
          start: "top 70%",
          toggleActions: "play none none reverse",
        },
      });
    }

    // Parallax interno da foto (a moldura fica; a imagem respira)
    const foto = section.querySelector<HTMLElement>("[data-descoberta-foto]");
    if (foto) {
      gsap.fromTo(
        foto,
        { yPercent: -4 },
        {
          yPercent: 4,
          ease: "none",
          scrollTrigger: {
            trigger: section,
            start: "top bottom",
            end: "bottom top",
            scrub: true,
          },
        },
      );
    }

    // Números contam ao entrar (restauram o texto exato ao final/interrupção)
    section
      .querySelectorAll<HTMLElement>("[data-contagem]")
      .forEach((el) => {
        const fim = parseFloat(el.dataset.contagem || "0");
        const pad = parseInt(el.dataset.contagemPad || "0", 10);
        const sufixo = el.dataset.contagemSufixo || "";
        const original = el.textContent;
        const restaura = () => {
          el.textContent = original;
        };
        const obj = { v: 0 };
        gsap.to(obj, {
          v: fim,
          duration: 1.4,
          ease: "power2.out",
          scrollTrigger: { trigger: el, start: "top 88%" },
          onUpdate() {
            el.textContent =
              String(Math.round(obj.v)).padStart(pad, "0") + sufixo;
          },
          onComplete: restaura,
          onInterrupt: restaura,
        });
      });
  });
</script>
