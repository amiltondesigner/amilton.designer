---
/**
 * Capítulo 02 — Descoberta. Quem pensa assim, sem seção "Sobre": um spread
 * editorial escuro onde o retrato INVADE o nome gigante (a foto entra sobre
 * a cauda de "Schlemper", como capa de revista). Entra o azul. O nome sobe
 * de máscaras (motion-assinatura global). Serviços viram uma linha
 * tipográfica (não mais grid que parece botão); os anos são um número
 * editorial, não contador de dashboard.
 *
 * Cenas só no desktop; o HTML nasce completo e visível (mobile/no-JS/reduced
 * empilham nome → foto e mostram tudo).
 */
import { Image } from "astro:assets";
import avatar from "../../assets/avatar.png";
import { site, services } from "../../config/site";
import Socials from "../Socials.astro";
import MarkFragment from "../MarkFragment.astro";
---

<section
  id="descoberta"
  data-chapter-section="descoberta"
  class="wrap scroll-mt-24 py-28 md:py-44 relative isolate"
>
  <!-- eco da marca: um pedaço do A+S que sobrou da explosão do hero -->
  <MarkFragment
    class="hidden md:block top-[10%] -left-[17rem] w-[820px] lg:w-[1040px]"
    intensidade={18}
  />

  <!-- Spread: o nome gigante e o retrato se sobrepõem -->
  <p class="kicker text-accent" data-anima="fade">Quem pensa assim</p>
  <div class="relative mt-8 grid grid-cols-1 gap-10 md:mt-10 md:grid-cols-12 md:items-start md:gap-0">
    <h2 class="display-1 relative z-20 md:col-span-8 md:col-start-1 md:row-start-1 md:mt-16">
      <span class="p-mask"><span class="p-mask-inner">Amilton</span></span>
      <span class="p-mask"><span class="p-mask-inner">Schlemper</span></span>
    </h2>

    <div
      class="relative z-0 md:col-span-5 md:col-start-8 md:row-start-1 md:-ml-8 lg:-ml-12"
      data-anima="scale"
    >
      <div class="aspect-[4/5] w-full overflow-hidden rounded-lg border border-border bg-surface">
        <Image
          src={avatar}
          alt={`Retrato de ${site.name}`}
          width={840}
          height={1050}
          class="h-full w-full scale-[1.08] object-cover"
          data-descoberta-foto
        />
      </div>
    </div>
  </div>

  <!-- A bio, assimétrica: a frase grande à esquerda, o número editorial dos
       anos à direita -->
  <div class="mt-20 grid grid-cols-1 gap-10 md:mt-28 md:grid-cols-12 md:gap-10">
    <div class="md:col-span-7">
      <p
        class="font-display text-3xl font-medium leading-[1.15] tracking-tight md:text-4xl"
        data-anima
      >
        {site.bio}
      </p>
      <p
        class="mt-8 max-w-xl text-lg leading-relaxed text-muted"
        data-anima
        data-anima-delay="0.1"
      >
        Comecei no <span class="text-accent font-medium">design gráfico</span>,
        passei pelo <span class="text-accent font-medium">web design</span> e
        virei <span class="text-accent font-medium">diretor de arte</span> em
        agência. Depois vieram anos
        desenhando <span class="text-accent font-medium">govtech</span> que
        prefeituras usam no dia a dia, e hoje desenho produto
        em <span class="text-accent font-medium">logística digital</span>. No
        meio disso, e-commerce, marcas e design systems. Muda o cliente e o
        setor; o trabalho é sempre o mesmo: fazer quem vê ou
        usa <span class="text-accent font-medium">entender de primeira</span>.
      </p>
    </div>

    <div class="md:col-span-4 md:col-start-9 md:self-end" data-anima="scale">
      <div class="flex items-baseline gap-3">
        <span
          class="font-display text-7xl font-semibold leading-none tabular-nums text-accent md:text-8xl"
        >
          {site.yearsOfExperience}
        </span>
        <span class="font-display text-3xl font-medium text-accent">anos</span>
      </div>
      <p class="mt-4 max-w-xs leading-relaxed text-muted">
        desenhando produto, do setor público à logística digital.
      </p>
    </div>
  </div>

  <!-- Serviços como linha tipográfica (não botões) -->
  <div class="mt-16 border-t border-border pt-8 md:mt-24" data-anima>
    <p class="eyebrow">O que eu faço</p>
    <p
      class="mt-5 font-display text-2xl font-medium leading-snug tracking-tight md:text-3xl"
    >
      {
        services.map((s, i) => (
          <>
            {s.label}
            {i < services.length - 1 && (
              <span class="px-2 text-accent">·</span>
            )}
          </>
        ))
      }
    </p>
  </div>

  <!-- Disponibilidade + redes -->
  <div
    class="mt-12 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-faint"
    data-anima="fade"
  >
    <span class="inline-flex items-center gap-2">
      <span class="size-1.5 rounded-full bg-accent"></span> Disponível para
      freelance
    </span>
    <span>{site.location}</span>
  </div>
  <div class="mt-6" data-anima="fade" data-anima-delay="0.1">
    <Socials />
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { registerScene } from "../../scripts/experience";

  registerScene(() => {
    const section = document.getElementById("descoberta");
    if (!section) return;

    // Parallax interno da foto (a moldura fica; a imagem respira)
    const foto = section.querySelector<HTMLElement>("[data-descoberta-foto]");
    if (foto) {
      gsap.fromTo(
        foto,
        { yPercent: -4 },
        {
          yPercent: 4,
          ease: "none",
          scrollTrigger: {
            trigger: section,
            start: "top bottom",
            end: "bottom top",
            scrub: true,
          },
        },
      );
    }
  });
</script>
