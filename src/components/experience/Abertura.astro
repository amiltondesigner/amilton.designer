---
/**
 * Capítulo 01 — Abertura. Impacto e silêncio: quase nenhuma informação,
 * muito espaço, o conceito do site dito na cara. Ver docs/VISION.md.
 */
import HeroMark from "../HeroMark.astro";
---

<section
  id="abertura"
  data-chapter-section="abertura"
  class="relative flex min-h-svh flex-col justify-center overflow-hidden"
>
  <HeroMark />

  <div class="wrap relative z-10">
    <p class="eyebrow">Amilton Schlemper · UI/UX Designer Sênior</p>
    <h1 class="display-1 mt-8 max-w-[14ch]" data-abertura-titulo>
      Um portfólio que não apresenta projetos.
    </h1>
    <p
      class="mt-8 max-w-md text-lg leading-relaxed text-muted md:text-xl"
      data-abertura-sub
    >
      Ele convida você pra dentro da forma como eu penso.
    </p>
  </div>

  <a
    href="#descoberta"
    class="wrap relative z-10 mt-16 inline-flex items-center gap-3 pb-10 text-sm text-muted transition-colors hover:text-foreground md:absolute md:bottom-0 md:mt-0"
  >
    <span class="scroll-cue" aria-hidden="true"></span> Role pra entrar
  </a>
</section>

<style>
  .scroll-cue {
    position: relative;
    display: inline-block;
    width: 1px;
    height: 2.5rem;
    background: linear-gradient(to bottom, var(--color-faint), transparent);
    overflow: hidden;
  }
  .scroll-cue::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--color-accent);
    animation: cue 2.2s var(--ease-out-expo) infinite;
  }
  @keyframes cue {
    0% {
      transform: translateY(-100%);
    }
    60%,
    100% {
      transform: translateY(100%);
    }
  }
</style>
