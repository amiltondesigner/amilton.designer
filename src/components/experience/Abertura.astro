---
/**
 * Capítulo 01 — Abertura. Impacto e silêncio: a frase-conceito nasce
 * palavra por palavra, e na saída (cena pinada, só desktop) se desmonta
 * deixando um instante de vazio antes da Descoberta. Ver docs/VISION.md.
 *
 * As palavras são divididas no build (spans mascarados); sem JS o texto
 * fica 100% visível e estático.
 *
 * Regra anti-conflito das cenas: a ENTRADA anima só os elementos internos
 * (.palavra-inner, .item-inner, svg da marca) e a SAÍDA pinada anima só os
 * contêineres (.palavra, [data-abertura-item], .hero-mark). Assim os dois
 * timelines nunca disputam a mesma propriedade do mesmo alvo.
 */
import HeroMark from "../HeroMark.astro";

const TITULO = "Um portfólio que não apresenta projetos.";
const palavras = TITULO.split(" ");
---

<section
  id="abertura"
  data-chapter-section="abertura"
  class="relative flex min-h-svh flex-col justify-center overflow-hidden"
>
  <HeroMark />

  <div class="wrap relative z-10">
    <p class="eyebrow" data-abertura-item>
      <span class="item-inner inline-block"
        >Amilton Schlemper · UI/UX Designer Sênior</span
      >
    </p>
    <h1 class="display-1 mt-8 max-w-[14ch]" data-abertura-titulo>
      {
        palavras.map((p) => (
          <>
            <span class="palavra"><span class="palavra-inner">{p}</span></span>
            {" "}
          </>
        ))
      }
    </h1>
    <p
      class="mt-8 max-w-md text-lg leading-relaxed text-muted md:text-xl"
      data-abertura-item
    >
      <span class="item-inner inline-block"
        >Ele convida você pra dentro da forma como eu penso.</span
      >
    </p>
  </div>

  <div
    data-abertura-item
    class="wrap relative z-10 mt-16 pb-10 md:absolute md:bottom-0 md:mt-0"
  >
    <span
      class="item-inner inline-flex flex-wrap items-center gap-x-6 gap-y-3"
    >
      <a
        href="#descoberta"
        class="inline-flex items-center gap-3 text-sm text-muted transition-colors hover:text-foreground"
      >
        <span class="scroll-cue" aria-hidden="true"></span> Role pra entrar
      </a>
      <a
        href="#evidencias"
        class="link-line text-xs text-faint transition-colors hover:text-foreground"
      >
        ou vá direto às provas
      </a>
    </span>
  </div>
</section>

<style>
  /* máscara por palavra — padding compensa descendentes (j, p, q) */
  .palavra {
    display: inline-block;
    overflow: hidden;
    vertical-align: top;
    padding-bottom: 0.14em;
    margin-bottom: -0.14em;
  }
  .palavra-inner {
    display: inline-block;
    will-change: transform;
  }

  .scroll-cue {
    position: relative;
    display: inline-block;
    width: 1px;
    height: 2.5rem;
    background: linear-gradient(to bottom, var(--faint), transparent);
    overflow: hidden;
  }
  .scroll-cue::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--ch-accent);
    animation: cue 2.2s var(--ease-out-expo) infinite;
  }
  @keyframes cue {
    0% {
      transform: translateY(-100%);
    }
    60%,
    100% {
      transform: translateY(100%);
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { registerScene } from "../../scripts/experience";

  registerScene(() => {
    const section = document.getElementById("abertura");
    if (!section) return;

    const palavrasInner =
      section.querySelectorAll<HTMLElement>(".palavra-inner");
    const palavras = section.querySelectorAll<HTMLElement>(".palavra");
    const itensInner = section.querySelectorAll<HTMLElement>(".item-inner");
    const itens = section.querySelectorAll<HTMLElement>(
      "[data-abertura-item]",
    );
    const marcaSvg = section.querySelector<HTMLElement>(".hero-mark__svg");
    const marca = section.querySelector<HTMLElement>(".hero-mark");

    // Entrada — silêncio, e a frase nasce de baixo, palavra a palavra
    const entrada = gsap.timeline({ defaults: { ease: "expo.out" } });
    entrada
      .from(palavrasInner, { yPercent: 115, duration: 1.05, stagger: 0.07 }, 0.15)
      .from(
        itensInner,
        { opacity: 0, y: 14, duration: 0.7, stagger: 0.12 },
        "-=0.55",
      );
    if (marcaSvg) {
      entrada.from(
        marcaSvg,
        { opacity: 0, duration: 1.6, ease: "power1.out" },
        0.4,
      );
    }

    // Saída pinada — a frase se desmonta e sobra um instante de vazio
    const saida = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: "top top",
        end: "+=70%",
        scrub: true,
        pin: true,
        anticipatePin: 1,
      },
      defaults: { ease: "none" },
    });
    saida
      .to(palavras, { yPercent: -140, opacity: 0, stagger: 0.03 }, 0)
      // itens somem rápido, antes das palavras cruzarem por cima (crítica)
      .to(itens, { opacity: 0, y: -24, duration: 0.22 }, 0);
    if (marca) saida.to(marca, { opacity: 0.25, yPercent: -6 }, 0);
  });
</script>
