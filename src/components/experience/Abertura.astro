---
/**
 * Capítulo 01 — Abertura. Impacto e silêncio: a frase-conceito nasce
 * palavra por palavra e, na saída (cena pinada, só desktop), o símbolo
 * A+S explode em direção à câmera enquanto a tela apaga — o visitante
 * atravessa a marca e cai no capítulo escuro da Descoberta.
 *
 * As palavras são divididas no build (spans mascarados); sem JS o texto
 * fica 100% visível e estático, e a camada escura nunca aparece (o tema
 * escuro do capítulo 02 continua vindo do IntersectionObserver).
 *
 * Regra anti-conflito das cenas: a ENTRADA anima só os elementos internos
 * (.palavra-inner, .item-inner) e a SAÍDA pinada anima os contêineres
 * (.palavra, [data-abertura-item]). A marca A+S fica estática no fundo
 * durante a entrada (fill do CSS) e só se move na saída, quando explode
 * em direção à câmera (scale/opacity via scrub).
 */
import HeroMark from "../HeroMark.astro";

const TITULO = "Antes do desenho, o pensamento.";
const palavras = TITULO.split(" ");
---

<section
  id="abertura"
  data-chapter-section="abertura"
  class="relative flex min-h-svh flex-col justify-center overflow-hidden"
>
  <!-- a luz apaga junto da explosão; cor = --ch-bg da Descoberta -->
  <div class="abertura-escuro" data-abertura-escuro aria-hidden="true"></div>
  <HeroMark />

  <div class="wrap relative z-10">
    <p class="eyebrow" data-abertura-item>
      <span class="item-inner inline-block"
        >Amilton Schlemper · Designer de produtos digitais</span
      >
    </p>
    <h1 class="display-1 mt-8 max-w-[16ch]" data-abertura-titulo>
      {
        palavras.map((p) => (
          <>
            <span class="palavra"><span class="palavra-inner">{p}</span></span>
            {" "}
          </>
        ))
      }
    </h1>
    <p
      class="mt-8 max-w-md text-lg leading-relaxed text-muted md:text-xl"
      data-abertura-item
    >
      <span class="item-inner inline-block"
        >Te mostro como eu penso um produto, do problema à solução.</span
      >
    </p>
  </div>

  <div
    data-abertura-item
    class="wrap relative z-10 mt-16 pb-10 md:absolute md:bottom-0 md:mt-0"
  >
    <span
      class="item-inner inline-flex flex-wrap items-center gap-x-6 gap-y-3"
    >
      <a
        href="#descoberta"
        class="inline-flex items-center gap-3 text-sm text-muted transition-colors hover:text-foreground"
      >
        <span class="scroll-cue" aria-hidden="true"></span> Role pra entrar
      </a>
      <a
        href="#evidencias"
        class="link-line text-xs text-faint transition-colors hover:text-foreground"
      >
        ou vá direto às provas
      </a>
    </span>
  </div>
</section>

<style>
  .abertura-escuro {
    position: absolute;
    inset: 0;
    z-index: 0; /* HeroMark vem depois no DOM: a marca explode SOBRE o escuro */
    background: #0f1522; /* espelha body[data-chapter="descoberta"] */
    opacity: 0;
    pointer-events: none;
  }

  /* máscara por palavra — padding compensa descendentes (j, p, q) */
  .palavra {
    display: inline-block;
    overflow: hidden;
    vertical-align: top;
    padding-bottom: 0.14em;
    margin-bottom: -0.14em;
  }
  .palavra-inner {
    display: inline-block;
    will-change: transform;
  }

  .scroll-cue {
    position: relative;
    display: inline-block;
    width: 1px;
    height: 2.5rem;
    background: linear-gradient(to bottom, var(--faint), transparent);
    overflow: hidden;
  }
  .scroll-cue::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--ch-accent);
    animation: cue 2.2s var(--ease-out-expo) infinite;
  }
  @keyframes cue {
    0% {
      transform: translateY(-100%);
    }
    60%,
    100% {
      transform: translateY(100%);
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { registerScene } from "../../scripts/experience";

  registerScene(() => {
    const section = document.getElementById("abertura");
    if (!section) return;

    const palavrasInner =
      section.querySelectorAll<HTMLElement>(".palavra-inner");
    const palavras = section.querySelectorAll<HTMLElement>(".palavra");
    const itensInner = section.querySelectorAll<HTMLElement>(".item-inner");
    const itens = section.querySelectorAll<HTMLElement>(
      "[data-abertura-item]",
    );
    const marcaSvg = section.querySelector<HTMLElement>(".hero-mark__svg");
    const marcaPath = section.querySelector<SVGPathElement>(".am-mark");
    const escuro = section.querySelector<HTMLElement>(
      "[data-abertura-escuro]",
    );

    // Entrada — silêncio, e a frase nasce de baixo, palavra a palavra
    const entrada = gsap.timeline({ defaults: { ease: "expo.out" } });
    entrada
      .from(palavrasInner, { yPercent: 115, duration: 1.05, stagger: 0.07 }, 0.15)
      .from(
        itensInner,
        { opacity: 0, y: 14, duration: 0.7, stagger: 0.12 },
        "-=0.55",
      );
    // A marca fica estática no fundo desde o load. Fixo o fill concreto que
    // espelha o CSS .am-mark: a explosão da saída interpola essa cor de origem
    // sem depender do color-mix() computado (que o GSAP não sabe ler).
    if (marcaPath) gsap.set(marcaPath, { fill: "rgba(28,25,23,0.14)" });

    // Saída pinada — a frase se desmonta, o símbolo explode e a luz apaga
    const saida = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: "top top",
        end: "+=110%",
        scrub: true,
        pin: true,
        anticipatePin: 1,
        // o capítulo escuro chega JUNTO da explosão; depois do pin o
        // IntersectionObserver do tema assume normalmente
        onUpdate(self) {
          const alvo = self.progress > 0.5 ? "descoberta" : "abertura";
          if (document.body.dataset.chapter !== alvo) {
            document.body.dataset.chapter = alvo;
          }
        },
      },
      defaults: { ease: "none" },
    });
    saida
      .to(palavras, { yPercent: -140, opacity: 0, stagger: 0.02, duration: 0.4 }, 0)
      // itens somem rápido, antes das palavras cruzarem por cima (crítica)
      .to(itens, { opacity: 0, y: -24, duration: 0.18 }, 0);
    if (marcaSvg) {
      saida
        // a marca cresce em direção à câmera: o visitante passa POR ela.
        // fromTo + immediateRender:false fixa o estado inicial (scale 1,
        // opacity 1) pro scrub REVERTER certo ao voltar pro topo — senão a
        // opacidade ficava presa em 0 (a entrada anima a mesma opacity, e o
        // .to gravava 0 como valor inicial).
        .fromTo(
          marcaSvg,
          { scale: 1 },
          {
            scale: 9.5,
            transformOrigin: "50% 50%",
            ease: "power2.in",
            duration: 0.75,
            immediateRender: false,
          },
          0.18,
        )
        .fromTo(
          marcaSvg,
          { opacity: 1 },
          { opacity: 0, duration: 0.22, immediateRender: false },
          0.82,
        );
    }
    if (marcaPath) {
      // o traço clareia enquanto o fundo escurece (independe do tema do body)
      saida.to(
        marcaPath,
        { fill: "rgba(250, 250, 247, 0.3)", duration: 0.28 },
        0.36,
      );
    }
    if (escuro) {
      saida.to(escuro, { opacity: 1, ease: "power1.in", duration: 0.45 }, 0.32);
    }
    saida.to({}, { duration: 0.12 }, 0.92); // respiro no escuro antes de soltar
  });
</script>
