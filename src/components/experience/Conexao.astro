---
/**
 * Capítulo 05 — Conexão. Contato como consequência da experiência.
 * Violeta. O builder de WhatsApp da v1 segue intacto na lógica;
 * o re-skin fino acontece na Fase 6.
 */
import WhatsAppBuilder from "../contact/WhatsAppBuilder.tsx";
import Socials from "../Socials.astro";
import SymbolMark from "../SymbolMark.astro";
import { site } from "../../config/site";

const year = new Date().getFullYear();
---

<section
  id="conexao"
  data-chapter-section="conexao"
  class="wrap scroll-mt-24 pt-28 md:pt-44"
>
  <p class="kicker text-accent">Capítulo 05 · Conexão</p>
  <div class="mt-6 max-w-3xl">
    <h2 class="display-2">Chegou até aqui. Vamos conversar?</h2>
    <p class="mt-6 max-w-xl text-lg text-muted">
      Monte sua mensagem em alguns toques, tudo opcional. Eu recebo no WhatsApp
      já com o contexto e respondo rápido. Sem formulário, sem espera.
    </p>
  </div>

  <WhatsAppBuilder client:visible />

  <footer class="mt-28 border-t border-border py-12">
    <div class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
      <div>
        <a href="#abertura" class="inline-flex items-center gap-2.5 font-medium">
          <SymbolMark class="size-6 shrink-0" /> Amilton Schlemper
        </a>
        <p class="mt-3 text-sm text-faint">{site.location}</p>
      </div>
      <Socials />
    </div>
    <div
      class="mt-10 flex flex-col gap-2 text-sm text-faint md:flex-row md:items-center md:justify-between"
    >
      <span class="tabular-nums"
        >© {year} {site.name} · Todos os direitos reservados</span
      >
      <a
        href="#abertura"
        class="link-line transition-colors hover:text-foreground"
        >Voltar ao começo ↑</a
      >
    </div>
  </footer>
</section>
