---
/**
 * Capítulo 04 — Evidências. Os projetos deixam de ser protagonistas:
 * comprovam o discurso do Pensamento. Verde. O overlay de case entra na
 * Fase 5; por ora os cards navegam pra /trabalho/[slug].
 */
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import MarkFragment from "../MarkFragment.astro";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<section
  id="evidencias"
  data-chapter-section="evidencias"
  class="wrap scroll-mt-24 py-28 md:py-44 relative isolate"
>
  <!-- eco da marca: um pedaço do A+S, agora em verde -->
  <MarkFragment
    class="hidden md:block bottom-[8%] -right-44 w-[520px] lg:w-[640px]"
    intensidade={11}
    rotacao={-8}
  />
  <p class="kicker text-accent" data-anima="fade">As provas</p>
  <div class="mt-6 flex flex-wrap items-end justify-between gap-6">
    <h2 class="display-2 max-w-[16ch]" data-anima>
      Projetos não abrem esta história. Comprovam.
    </h2>
    <span class="text-sm tabular-nums text-faint" data-anima="fade">
      {String(projects.length).padStart(2, "0")} evidências
    </span>
  </div>

  <div
    class="mt-14 grid grid-cols-1 gap-x-6 gap-y-12 md:mt-20 md:grid-cols-12 md:gap-y-24"
  >
    {
      projects.map((p, i) => (
        <a
          href={`/trabalho/${p.id}`}
          data-anima="scale"
          class:list={[
            "group block",
            p.data.span === "wide" ? "md:col-span-7" : "md:col-span-5",
            i % 2 === 1 && "md:mt-16",
          ]}
        >
          <div
            class="relative overflow-hidden rounded-lg border border-border bg-surface transition-colors duration-500 group-hover:border-accent/40"
          >
            <div class="aspect-[4/3] w-full">
              {p.data.cover ? (
                <Image
                  src={p.data.cover}
                  alt={p.data.title}
                  widths={[480, 768, 1024]}
                  sizes="(max-width: 768px) 100vw, 45vw"
                  class="h-full w-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-105"
                />
              ) : (
                <span
                  aria-hidden="true"
                  class="absolute inset-0 flex items-center justify-center font-display font-semibold tracking-tighter text-faint text-[clamp(3rem,10vw,6rem)]"
                >
                  {p.data.glyph ?? p.data.title.slice(0, 2)}
                </span>
              )}
            </div>
            <span class="absolute right-4 top-4 flex size-9 -translate-y-1.5 items-center justify-center rounded-full bg-foreground text-background opacity-0 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:translate-y-0 group-hover:opacity-100">
              ↗
            </span>
          </div>

          <div class="mt-5 flex items-baseline justify-between gap-4">
            <h3
              class="font-display text-2xl font-semibold tracking-tight transition-colors duration-300 group-hover:text-accent md:text-3xl"
            >
              {p.data.title}
            </h3>
            <span class="shrink-0 text-sm tabular-nums text-faint">
              {p.data.year}
            </span>
          </div>
          <p class="mt-2 max-w-prose text-muted">{p.data.summary}</p>
          <div class="mt-3 flex items-center justify-between gap-4">
            <p class="eyebrow">{p.data.category}</p>
            <span class="inline-flex items-center gap-1.5 text-sm text-faint transition-colors group-hover:text-accent">
              Ver a prova
              <span
                aria-hidden="true"
                class="transition-transform group-hover:translate-x-0.5"
              >
                →
              </span>
            </span>
          </div>
        </a>
      ))
    }
  </div>
</section>
