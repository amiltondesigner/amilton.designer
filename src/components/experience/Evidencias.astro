---
/**
 * Capítulo 04 — Evidências. Os projetos deixam de ser "lista": viram uma
 * EXPOSIÇÃO de provas numeradas (Prova 01…04). Cada prova é uma linha
 * editorial de largura cheia, com a imagem grande alternando de lado e um
 * número-índice grande ancorando a leitura. Verde. Os cards navegam pro
 * overlay/página do case (/trabalho/[slug]).
 */
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<section
  id="evidencias"
  data-chapter-section="evidencias"
  class="wrap scroll-mt-24 py-28 md:py-44 relative isolate"
>
  <!-- Cabeçalho assimétrico: a tese à esquerda, a contagem como número-marco -->
  <div class="grid grid-cols-1 gap-8 md:grid-cols-12 md:items-end">
    <div class="md:col-span-9">
      <p class="kicker text-accent" data-anima="fade">A exposição</p>
      <h2 class="display-1 mt-6 max-w-[15ch]">
        <span class="p-mask"
          ><span class="p-mask-inner">Projetos não abrem esta história.</span
          ></span
        >
        <span class="p-mask"
          ><span class="p-mask-inner text-accent">Comprovam.</span></span
        >
      </h2>
    </div>
    <div class="md:col-span-3 md:text-right" data-anima="fade">
      <span class="font-display text-5xl font-semibold tabular-nums md:text-6xl">
        {String(projects.length).padStart(2, "0")}
      </span>
      <span class="eyebrow mt-2 block md:text-right">provas em exposição</span>
    </div>
  </div>

  <!-- As provas: linhas editoriais alternadas -->
  <div class="mt-24 flex flex-col gap-24 md:mt-36 md:gap-40">
    {
      projects.map((p, i) => {
        const par = i % 2 === 0;
        const num = String(i + 1).padStart(2, "0");
        return (
          <a
            href={`/trabalho/${p.id}`}
            data-anima="scale"
            class="group grid grid-cols-1 gap-y-6 md:grid-cols-12 md:items-center md:gap-x-12"
          >
            <div
              class:list={[
                "md:col-span-7",
                par ? "md:col-start-1" : "md:col-start-6",
              ]}
            >
              <div class="relative overflow-hidden rounded-lg border border-border bg-surface transition-colors duration-500 group-hover:border-accent/40">
                <div class="aspect-[4/3] w-full">
                  {p.data.cover ? (
                    <Image
                      src={p.data.cover}
                      alt={p.data.title}
                      widths={[480, 768, 1200]}
                      sizes="(max-width: 768px) 100vw, 58vw"
                      class="h-full w-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.04]"
                    />
                  ) : (
                    <span
                      aria-hidden="true"
                      class="absolute inset-0 flex items-center justify-center font-display font-semibold tracking-tighter text-faint text-[clamp(3rem,10vw,6rem)]"
                    >
                      {p.data.glyph ?? p.data.title.slice(0, 2)}
                    </span>
                  )}
                </div>
              </div>
            </div>

            <div
              class:list={[
                "md:col-span-4 md:row-start-1",
                par ? "md:col-start-9" : "md:col-start-1",
              ]}
            >
              <div class="flex items-baseline gap-3">
                <span class="font-display text-5xl font-semibold tabular-nums leading-none text-accent md:text-6xl">
                  {num}
                </span>
                <span class="eyebrow">Prova</span>
              </div>
              <h3 class="mt-5 font-display text-3xl font-semibold tracking-tight transition-colors duration-300 group-hover:text-accent md:text-4xl">
                {p.data.title}
              </h3>
              <p class="mt-3 max-w-prose leading-relaxed text-muted">
                {p.data.summary}
              </p>
              <div class="mt-6 flex items-center justify-between gap-4 border-t border-border pt-4">
                <span class="eyebrow">
                  {p.data.category} · {p.data.year}
                </span>
                <span class="inline-flex items-center gap-1.5 text-sm text-faint transition-colors group-hover:text-accent">
                  Ver a prova
                  <span
                    aria-hidden="true"
                    class="transition-transform duration-300 group-hover:translate-x-1"
                  >
                    →
                  </span>
                </span>
              </div>
            </div>
          </a>
        );
      })
    }
  </div>
</section>
